# ============================================================
# The Panel — environment template
# Copy this file to ".env" and paste your real keys there.
#   cp .env.example .env
# Never commit the real .env (it's git-ignored).
# ============================================================

# --- API KEYS (required) ---

# Brain (LLM). https://platform.openai.com
OPENAI_API_KEY=

# Ears (speech-to-text). https://console.deepgram.com  (free credits)
DEEPGRAM_API_KEY=

# Voices (text-to-speech). https://play.cartesia.ai  (free tier)
CARTESIA_API_KEY=


# --- CONFIG (optional; sensible defaults shown) ---
LLM_MODEL=gpt-4o
CARTESIA_MODEL=sonic-2
PORT=8000
